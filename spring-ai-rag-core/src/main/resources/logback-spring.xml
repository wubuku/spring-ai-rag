<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="spring-ai-rag"/>

    <!--
        Log output modes:
        - default/dev: Human-readable text format (colored console)
        - prod/test:   JSON structured format (for ELK/Loki log aggregation systems)

        Sensitive data masking:
        - SensitiveDataMaskingConverter automatically scans log messages and masks passwords/API keys/tokens
        - SensitiveMdc.put(key, value) for programmatic sensitive MDC values (auto-masked)
        - Supported patterns: JSON fields, URL query params, Key-Value pairs, Authorization headers
    -->

    <!-- Register global sensitive data masking converter (for dev/default plain-text format) -->
    <conversionRule conversionWord="maskedMsg"
                    converterClass="com.springairag.core.logging.SensitiveDataMaskingConverter"/>

    <!-- ====== Development: Human-readable colored console output ====== -->
    <springProfile name="default,dev">
        <property name="LOG_PATTERN"
                  value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-no-trace}] %-5level %logger{36} - %maskedMsg%n"/>

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.springairag" level="INFO"/>
    </springProfile>

    <!-- ====== Production/Test: JSON structured logs (with auto sensitive data masking) ====== -->
    <springProfile name="prod,test">
        <!--
            Logstash JSON Encoder + sensitive data masking
            Output fields:
              @timestamp  - ISO8601 timestamp
              msg         - Log message (already masked for sensitive data)
              level       - Log level
              logger      - Logger name
              thread      - Thread name
              stack_trace - Stack trace (optional)
              traceId     - Request trace ID (MDC)
              domainId    - Collection ID (MDC)
              userId      - User ID (MDC)
              application - Application name (customFields)

            Sensitive data masking patterns (auto-processed):
              - JSON: "password":"xxx", "apiKey":"xxx", "token":"xxx", "secret":"xxx"
              - URL:  ?password=xxx, ?apiKey=xxx, ?token=xxx
              - KV:   password=xxx, apiKey=xxx, token=xxx
              - Header: Authorization: Bearer xxx, Basic xxx
              - AWS: AKIAIOSFODNN7EXAMPLE
        -->
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <!-- MaskingLogstashEncoder applies sensitive data masking before JSON encoding -->
            <encoder class="com.springairag.core.logging.MaskingLogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>domainId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>sessionId</includeMdcKeyName>
                <customFields>{"application":"${appName}"}</customFields>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <message>msg</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                    <stackTrace>stack_trace</stackTrace>
                </fieldNames>
                <!-- Limit stack trace to 20 lines to prevent log explosion -->
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerThrowable>20</maxDepthPerThrowable>
                    <maxLength>4096</maxLength>
                    <shortenedClassNameLength>50</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>

        <!-- Spring/JPA framework log noise reduction (WARN and above only) -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <!-- RAG business logs at INFO level -->
        <logger name="com.springairag" level="INFO"/>
    </springProfile>

</configuration>
