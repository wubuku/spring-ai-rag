<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="spring-ai-rag"/>

    <!--
        日志输出模式：
        - default/dev: 人类可读文本格式（彩色控制台）
        - prod/test:   JSON 结构化格式（便于 ELK/Loki 等日志聚合系统解析）

        敏感数据脱敏：
        - SensitiveDataMaskingConverter 自动扫描日志消息，屏蔽密码/API Key/Token 等敏感字段
        - SensitiveMdc.put(key, value) 用于程序化设置敏感 MDC 值（自动屏蔽）
        - 支持模式：JSON字段、URL查询参数、Key-Value对、Authorization请求头
    -->

    <!-- 注册全局敏感数据屏蔽转换器（适用于 dev/default 的明文格式） -->
    <conversionRule conversionWord="maskedMsg"
                    converterClass="com.springairag.core.logging.SensitiveDataMaskingConverter"/>

    <!-- ====== 开发环境：人类可读的彩色控制台输出 ====== -->
    <springProfile name="default,dev">
        <property name="LOG_PATTERN"
                  value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-no-trace}] %-5level %logger{36} - %maskedMsg%n"/>

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.springairag" level="INFO"/>
    </springProfile>

    <!-- ====== 生产/测试环境：JSON 结构化日志（敏感数据自动屏蔽） ====== -->
    <springProfile name="prod,test">
        <!--
            Logstash JSON Encoder 配置 + 敏感数据屏蔽
            输出字段：
              @timestamp  - ISO8601 时间戳
              msg         - 日志消息（敏感数据已屏蔽）
              level       - 日志级别
              logger      - Logger 名称
              thread      - 线程名
              stack_trace - 堆栈（可选）
              traceId     - 请求追踪 ID（MDC）
              domainId    - 知识库 ID（MDC）
              userId      - 用户 ID（MDC）
              application - 应用名（customFields）

            敏感数据屏蔽模式（自动处理）：
              - JSON: "password":"xxx", "apiKey":"xxx", "token":"xxx", "secret":"xxx"
              - URL:  ?password=xxx, ?apiKey=xxx, ?token=xxx
              - KV:   password=xxx, apiKey=xxx, token=xxx
              - Header: Authorization: Bearer xxx, Basic xxx
              - AWS: AKIAIOSFODNN7EXAMPLE
        -->
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <!-- MaskingLogstashEncoder 在 JSON 编码前对消息应用敏感数据屏蔽 -->
            <encoder class="com.springairag.core.logging.MaskingLogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>domainId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>sessionId</includeMdcKeyName>
                <customFields>{"application":"${appName}"}</customFields>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <message>msg</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                    <stackTrace>stack_trace</stackTrace>
                </fieldNames>
                <!-- 栈 trace 限制 20 行，防止日志爆炸 -->
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerThrowable>20</maxDepthPerThrowable>
                    <maxLength>4096</maxLength>
                    <shortenedClassNameLength>50</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>

        <!-- Spring/JPA 框架日志降噪（只输出 WARN 及以上） -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <!-- RAG 业务日志 INFO 级别 -->
        <logger name="com.springairag" level="INFO"/>
    </springProfile>

</configuration>
