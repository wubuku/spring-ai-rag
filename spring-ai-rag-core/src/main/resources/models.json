{
  "providers": {
    "openai": {
      "displayName": "DeepSeek",
      "enabled": true,
      "priority": 1,
      "apiKey": "${OPENAI_API_KEY:dummy}",
      "chatModel": {
        "baseUrl": "https://api.deepseek.com",
        "model": "deepseek-chat",
        "temperature": 0.7,
        "maxTokens": 8192
      },
      "embeddingModel": {
        "baseUrl": "https://api.deepseek.com",
        "model": "deepseek-text-embedding",
        "dimension": 1024
      }
    },
    "anthropic": {
      "displayName": "Claude 3.5",
      "enabled": false,
      "priority": 2,
      "apiKey": "${ANTHROPIC_API_KEY:dummy}",
      "chatModel": {
        "baseUrl": "https://api.anthropic.com",
        "model": "claude-3-5-sonnet-20241022",
        "temperature": 0.7,
        "maxTokens": 8192
      }
    },
    "minimax": {
      "displayName": "MiniMax",
      "enabled": false,
      "priority": 3,
      "apiKey": "${MINIMAX_API_KEY:dummy}",
      "chatModel": {
        "baseUrl": "https://api.minimaxi.com",
        "model": "MiniMax-Text-01",
        "temperature": 0.7,
        "maxTokens": 8192
      },
      "embeddingModel": {
        "baseUrl": "https://api.minimaxi.com",
        "model": "embo-01",
        "dimension": 1024
      }
    }
  },
  "routing": {
    "defaultProvider": "openai",
    "fallbackChain": ["openai", "anthropic", "minimax"]
  }
}
