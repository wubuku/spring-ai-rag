# ============================================
# Spring AI RAG Environment Variables Template
# Copy to .env and fill in real values
# ============================================

# ══════════════════════════════════════════════════════════
# PostgreSQL Database Configuration
# ══════════════════════════════════════════════════════════
POSTGRES_DATABASE=spring_ai_rag_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5

# Spring Boot datasource URL (optional, takes precedence over individual host/port/db)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spring_ai_rag_dev
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# ══════════════════════════════════════════════════════════
# LLM Provider Selection (3 modes)
# ══════════════════════════════════════════════════════════
# Values:
#   openai     — OpenAI API compatible models (DeepSeek / Zhipu / SiliconFlow etc.)
#   anthropic  — Anthropic API compatible models (VolcEngine ARK MiniMax etc.)
#   minimax    — Spring AI native MiniMax starter
LLM_PROVIDER=openai

# ══════════════════════════════════════════════════════════
# OpenAI API Compatible Model (used when LLM_PROVIDER=openai)
# Applicable to: DeepSeek, Zhipu, SiliconFlow (International) etc.
# ══════════════════════════════════════════════════════════
#
# IMPORTANT: base-url must NOT include /v1 suffix!
# Spring AI's OpenAiApi automatically appends /v1/chat/completions
# If base-url contains /v1, the final URL becomes /v1/v1/... → 401/404
# Reference: https://github.com/spring-projects/spring-ai/issues/710
SPRING_AI_OPENAI_API_KEY=sk-your-openai-compatible-key
SPRING_AI_OPENAI_BASE_URL=https://api.deepseek.com
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7

# SiliconFlow OpenAI Compatible Configuration (example)
# SPRING_AI_OPENAI_API_KEY=sk-your-siliconflow-key
# SPRING_AI_OPENAI_BASE_URL=https://api.siliconflow.cn
# SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=Qwen/Qwen2.5-7B-Instruct

# ══════════════════════════════════════════════════════════
# Anthropic API Compatible Model (used when LLM_PROVIDER=anthropic)
# Applicable to: VolcEngine ARK MiniMax etc.
# ══════════════════════════════════════════════════════════
# IMPORTANT: base-url must NOT include /v1 suffix!
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# ══════════════════════════════════════════════════════════
# Spring AI Native MiniMax Support (used when LLM_PROVIDER=minimax)
# Requires spring-ai-starter-model-minimax dependency
# API Key: https://platform.minimax.com
# ══════════════════════════════════════════════════════════
# IMPORTANT: base-url must NOT include /v1 suffix!
SPRING_AI_MINIMAX_API_KEY=sk-your-minimax-key
SPRING_AI_MINIMAX_BASE_URL=https://api.minimaxi.com
SPRING_AI_MINIMAX_CHAT_OPTIONS_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.7

# ══════════════════════════════════════════════════════════
# Embedding Model Configuration (SiliconFlow BGE-M3, always active)
# Used for: vector retrieval, hybrid search
# ══════════════════════════════════════════════════════════
# IMPORTANT: URL must NOT include /v1 path!
# Spring AI's OpenAiEmbeddingModel automatically appends /v1/embeddings
# If configured with /v1, final URL becomes https://api.siliconflow.cn/v1/embeddings → 404!
# Correct: https://api.siliconflow.cn
# Wrong:   https://api.siliconflow.cn/v1 ❌
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024

# ══════════════════════════════════════════════════════════
# Speech Recognition (Transcription) Model Configuration
# Used for: audio file transcription to text
# ══════════════════════════════════════════════════════════
TRANSCRIPTION_BASE_URL=https://open.bigmodel.cn/api/paas
TRANSCRIPTION_API_KEY=your-transcription-api-key
TRANSCRIPTION_MODEL=glm-asr-2512

# ══════════════════════════════════════════════════════════
# Vision Model Configuration (VolcEngine ARK service)
# Used for: multimodal chat (image understanding)
# Note: base-url should only go up to /api/v3, do not include /chat/completions
# ══════════════════════════════════════════════════════════
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_API_KEY=your-ark-vision-api-key
VISION_MODEL=doubao-1-5-vision-pro-32k-250115

# ══════════════════════════════════════════════════════════
# Application Configuration
# ══════════════════════════════════════════════════════════
# Application port (default 8080)
APP_PORT=8080

# Spring profiles (optional)
# SPRING_PROFILES_ACTIVE=postgresql

# ══════════════════════════════════════════════════════════
# E2E Test Configuration (optional, local development only)
# ══════════════════════════════════════════════════════════
# Test image file path (for multimodal streaming chat test)
# TEST_IMAGE_PATH=/path/to/your/test-image.jpg
# Test audio file path (for voice streaming chat test)
# TEST_AUDIO_PATH=/path/to/your/test-audio.mp3
