# ============================================
# Spring AI RAG 环境变量示例
# 复制为 .env 后填入真实值
# ============================================

# ══════════════════════════════════════════════════════════
# PostgreSQL 数据库配置
# ══════════════════════════════════════════════════════════
POSTGRES_DB=spring_ai_rag_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5

# Spring Boot 数据源 URL（可选，优先级高于分立的 host/port/db）
# 如使用此格式，上方的 POSTGRES_HOST/POSTGRES_PORT/POSTGRES_DB 将被忽略
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spring_ai_rag_dev
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# ══════════════════════════════════════════════════════════
# LLM 提供者选择（3 种模式）
# ══════════════════════════════════════════════════════════
# 可选值：
#   openai     — OpenAI API 兼容模型（DeepSeek / 智谱 / SiliconFlow 等）
#   anthropic  — Anthropic API 兼容模型（火山引擎 ARK MiniMax 等）
#   minimax    — Spring AI 原生 MiniMax starter
LLM_PROVIDER=openai

# ══════════════════════════════════════════════════════════
# OpenAI API 兼容模型（当 LLM_PROVIDER=openai 时使用）
# 适用于：DeepSeek、智谱、SiliconFlow（国际版）等
# ══════════════════════════════════════════════════════════
#
# ⚠️ 重要：base-url 不要带 /v1 后缀！
# Spring AI 的 OpenAiApi 会自动追加 /v1/chat/completions
# 如果 base-url 包含 /v1，最终 URL 会变成 /v1/v1/chat/completions → 401/404
# 参考：https://github.com/spring-projects/spring-ai/issues/710
OPENAI_API_KEY=sk-your-openai-compatible-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7

# SiliconFlow OpenAI 兼容配置（示例）
# SPRING_AI_OPENAI_API_KEY=sk-your-siliconflow-key
# SPRING_AI_OPENAI_BASE_URL=https://api.siliconflow.cn
# SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=Qwen/Qwen2.5-7B-Instruct

# ══════════════════════════════════════════════════════════
# Anthropic API 兼容模型（当 LLM_PROVIDER=anthropic 时使用）
# 适用于：火山引擎 ARK MiniMax 等
# ══════════════════════════════════════════════════════════
# ⚠️ 重要：base-url 不要带 /v1 后缀！
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# 火山引擎 ARK MiniMax（Anthropic API 兼容）示例
# ANTHROPIC_API_KEY=your-ark-minimax-key
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_MODEL=MiniMax-M2.5

# ══════════════════════════════════════════════════════════
# Spring AI 原生 MiniMax 支持（当 LLM_PROVIDER=minimax 时使用）
# 需要添加 spring-ai-starter-model-minimax 依赖
# API Key 来源：https://platform.minimax.com
# ══════════════════════════════════════════════════════════
# ⚠️ 重要：base-url 不要带 /v1 后缀！
SPRING_AI_MINIMAX_API_KEY=sk-your-minimax-key
SPRING_AI_MINIMAX_BASE_URL=https://api.minimaxi.com
SPRING_AI_MINIMAX_CHAT_OPTIONS_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.7

# ══════════════════════════════════════════════════════════
# 嵌入模型配置（SiliconFlow BGE-M3，始终生效）
# 用于：向量检索、混合搜索
# ══════════════════════════════════════════════════════════
# ⚠️ 重要提示：URL 不要带 /v1 路径！
# Spring AI 的 OpenAiEmbeddingModel 会自动在 base-url 后追加 /v1/embeddings
# 如果配置了 /v1，最终 URL 会变成 https://api.siliconflow.cn/v1/embeddings → 404 错误！
# 正确示例：https://api.siliconflow.cn
# 错误示例：https://api.siliconflow.cn/v1 ❌
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024

# ══════════════════════════════════════════════════════════
# 语音识别（转写）模型配置
# 用于：音频文件转写为文本
# ══════════════════════════════════════════════════════════
TRANSCRIPTION_BASE_URL=https://open.bigmodel.cn/api/paas
TRANSCRIPTION_API_KEY=your-transcription-api-key
TRANSCRIPTION_MODEL=glm-asr-2512

# ══════════════════════════════════════════════════════════
# 视觉模型配置（使用火山引擎 ARK 服务）
# 用于：多模态聊天（图片理解）
# 注意：base-url 只配置到版本号 /api/v3，不要包含 /chat/completions
# ══════════════════════════════════════════════════════════
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_API_KEY=your-ark-vision-api-key
VISION_MODEL=doubao-1-5-vision-pro-32k-250115

# ══════════════════════════════════════════════════════════
# 应用配置
# ══════════════════════════════════════════════════════════
# 应用端口（默认 8080）
APP_PORT=8080

# Spring profiles（可选）
# SPRING_PROFILES_ACTIVE=postgresql

# ══════════════════════════════════════════════════════════
# E2E 测试配置（可选，仅本地开发测试使用）
# ══════════════════════════════════════════════════════════
# 测试用图片文件路径（用于多模态流式聊天测试）
# TEST_IMAGE_PATH=/path/to/your/test-image.jpg
# 测试用音频文件路径（用于语音流式聊天测试）
# TEST_AUDIO_PATH=/path/to/your/test-audio.mp3
