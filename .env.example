# ============================================
# Spring AI RAG 环境变量示例
# 复制为 .env 后填入真实值
# ============================================

# PostgreSQL 数据库配置
POSTGRES_DB=spring_ai_rag_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5

# LLM 提供者选择
# 可选值：openai（默认）| anthropic | minimax
LLM_PROVIDER=openai

# OpenAI 兼容模型（DeepSeek / 智谱 / SiliconFlow 等）
# provider=openai 时使用
OPENAI_API_KEY=sk-your-openai-compatible-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7

# Anthropic 模型（Claude 系列）
# provider=anthropic 时使用
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# MiniMax 模型
# provider=minimax 时使用
# API Key 来源：https://platform.minimaxi.com
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.7

# 嵌入模型（SiliconFlow BGE-M3，始终生效）
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024

# 应用端口
APP_PORT=8080
