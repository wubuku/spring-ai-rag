# 使用 DeepSeek 模型（OpenAI API 兼容配置）
OPENAI_API_KEY=sk-7da4ef527ae8452e82bda1cec1c713fc
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# 使用 `OPENAI_` 前缀表示我们采用的是 OpenAI API 兼容的服务

# 使用 MiniMax-M2.7 模型（OpenAI API 兼容配置）
# OPENAI_API_KEY=sk-cp-aQMi7fO-byzDNLMHHlJClGq5Z7N9QqtZeRWDysikG4peDBYRRIYUbdtYgYP2jlUFX7WBcpRdoWhdyFI-Dgp5JH7f5CxV76IVMWZCCCp3zeVGQQRtdcPsUIw
# OPENAI_BASE_URL=https://api.minimaxi.com
# OPENAI_MODEL=MiniMax-M2.7

# 似乎不能使用 /v1 路径：
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# 国际版似乎是：
# OPENAI_BASE_URL=https://api.minimax.io/v1


# 可以将模型从 OpenAI API 兼容模型服务切换为 Anthropic API 兼容模型服务：
# LLM_PROVIDER=anthropic
# Anthropic API 兼容模型配置（实际使用 Minimax）
ANTHROPIC_API_KEY=sk-cp-aQMi7fO-byzDNLMHHlJClGq5Z7N9QqtZeRWDysikG4peDBYRRIYUbdtYgYP2jlUFX7WBcpRdoWhdyFI-Dgp5JH7f5CxV76IVMWZCCCp3zeVGQQRtdcPsUIw
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.5

# 启用 Spring AI 原生 MiniMax 支持 - 使用 spring-ai-starter-model-minimax
# LLM_PROVIDER=minimax
# MiniMax 配置
# Minimax Token Plan API Key
SPRING_AI_MINIMAX_API_KEY=sk-cp-aQMi7fO-byzDNLMHHlJClGq5Z7N9QqtZeRWDysikG4peDBYRRIYUbdtYgYP2jlUFX7WBcpRdoWhdyFI-Dgp5JH7f5CxV76IVMWZCCCp3zeVGQQRtdcPsUIw
SPRING_AI_MINIMAX_BASE_URL=https://api.minimaxi.com
SPRING_AI_MINIMAX_CHAT_OPTIONS_MODEL=MiniMax-M2.7


# SiliconFlow 嵌入模型配置（用于 VectorStoreChatMemoryAdvisor）
# ⚠️ 重要提示：URL 千万不要带 /v1 路径！
# Spring AI 的 OpenAiEmbeddingModel 会自动在 base-url 后追加 /v1/embeddings
# 如果配置了 /v1，最终 URL 会变成 https://api.siliconflow.cn/v1/v1/embeddings，导致 404 错误！
# 正确示例：https://api.siliconflow.cn
# 错误示例：https://api.siliconflow.cn/v1 ❌
SILICONFLOW_API_KEY=sk-denicaowawxspumyxgytvmoasrjfvmmisegvehozxoixrhbj
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024
SILICONFLOW_URL=https://api.siliconflow.cn

# PostgreSQL 数据库配置
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spring-ai-skills-demo
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
# 已经在测试数据库 spring-ai-skills-demo 中安装 vector 扩展和 pg_jieba 扩展
# create extension vector;
# CREATE EXTENSION pg_jieba;
# SELECT * FROM pg_available_extensions; -- 验证扩展安装
# **注**：目前 pg_jieba 扩展尚未被使用

# 如果在容器内连接宿主机数据库，将 localhost 替换为 host.docker.internal

